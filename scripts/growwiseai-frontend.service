[Unit]
Description=GrowWiseAI Frontend
After=network.target growwiseai-backend.service

[Service]
Type=simple
User=sean
WorkingDirectory=/home/sean/mlproject/frontend
ExecStart=/usr/bin/npx serve -s dist -l 5173 -L
Restart=always
RestartSec=10

# Logging
StandardOutput=append:/var/log/growwiseai-frontend.log
StandardError=append:/var/log/growwiseai-frontend-error.log

[Install]
WantedBy=multi-user.target

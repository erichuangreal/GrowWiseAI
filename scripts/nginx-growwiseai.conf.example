# GrowWiseAI – nginx reverse proxy (production)
# Backend runs on 127.0.0.1:8001. Nginx serves the built frontend and proxies /api.
#
# 1. Build frontend:  cd frontend && npm run build
# 2. Install:         sudo cp scripts/nginx-growwiseai.conf.example /etc/nginx/sites-available/growwiseai
# 3. Edit server_name and root if needed, then:
#    sudo ln -s /etc/nginx/sites-available/growwiseai /etc/nginx/sites-enabled/
#    sudo nginx -t && sudo systemctl reload nginx
# 4. Optional SSL (HTTPS): use certbot with nginx, e.g.:
#    sudo certbot --nginx -d growwiseai.erichuangreal.dev

server {
    listen 80;
    server_name growwiseai.erichuangreal.dev;   # replace with your domain or leave _ for default

    root /var/www/growwiseai;
    index index.html;

    # SPA: all non-file routes go to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API to backend (only thing on port 8001)
    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Optional: health check through nginx
    location /health {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}

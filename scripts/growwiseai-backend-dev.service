[Unit]
Description=GrowWiseAI Backend API (Development)
After=network.target

[Service]
Type=simple
User=sean
WorkingDirectory=/home/sean/mlproject
Environment="PATH=/home/sean/mlproject/venv/bin"
ExecStart=/home/sean/mlproject/venv/bin/uvicorn backend.main:app --reload --host 127.0.0.1 --port 8001
Restart=always
RestartSec=10

# Environment file
EnvironmentFile=/home/sean/mlproject/googlies.env

# Logging
StandardOutput=append:/var/log/growwiseai-backend-dev.log
StandardError=append:/var/log/growwiseai-backend-dev-error.log

[Install]
WantedBy=multi-user.target
